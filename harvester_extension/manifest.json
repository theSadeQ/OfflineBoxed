{
  "manifest_version": 3,
  "name": "OfflineBoxd Harvester Assistant",
  "version": "1.1",
  "description": "Interactive, 100% CAPTCHA-proof browser-driven scraping assistant for your offline movie database.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://letterboxd.com/*",
        "https://*.rottentomatoes.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
